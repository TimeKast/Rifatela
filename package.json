{
  "name": "timekast-starter-kit",
  "version": "0.0.0",
  "agentKitVersion": "9.1.0",
  "factoryVersion": "6.0.1",
  "ports": {
    "dev": 3002,
    "e2e": 3006
  },
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "node scripts/tools/dev.mjs",
    "dev:next": "NODE_OPTIONS='--max-old-space-size=2048' next dev --turbopack",
    "prebuild": "pnpm generate:email-logo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "update-board": "tsx scripts/tools/update-board.ts",
    "board:status": "tsx scripts/tools/board-status.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx scripts/tools/e2e-runner.ts",
    "test:e2e:direct": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "knip": "knip",
    "analyze": "next build && node scripts/tools/analyze-bundle.mjs",
    "env:check": "tsx scripts/tools/env-check.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:query": "tsx scripts/tools/db-query.ts",
    "db:seed": "tsx --require dotenv/config src/lib/db/seed.ts dotenv_config_path=.env.local",
    "db:seed:admin": "tsx --require dotenv/config src/lib/db/seeds/admin.ts dotenv_config_path=.env.local",
    "prepare": "husky",
    "pwa:check": "echo 'Starting Lighthouse PWA audit...' && npx lighthouse http://localhost:3000 --only-categories=pwa --output=html --output-path=./lighthouse-pwa.html && echo 'Report saved to lighthouse-pwa.html'",
    "setup:e2e": "tsx scripts/tools/setup-e2e.ts",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect --url=http://localhost:3000",
    "lighthouse:assert": "lhci assert",
    "generate:email-logo": "tsx scripts/tools/generate-email-logo.ts",
    "generate:inventory": "node scripts/tools/generate-inventory.mjs",
    "generate:codebase": "node scripts/tools/generate-codebase.mjs",
    "generate:hooks": "node scripts/tools/generate-hooks.mjs",
    "skill:lint": "tsx scripts/tools/skill-lint/index.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.43.0",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.562.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.1",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@serwist/turbopack": "^9.5.7",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.4",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^5.86.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "serwist": "^9.5.7",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md}": [
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@auth/core>nodemailer": "^7.0.12",
      "esbuild": ">=0.25.0",
      "picomatch": "^4.0.4"
    }
  }
}
