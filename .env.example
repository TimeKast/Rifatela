# ===========================================
# TimeKast Starter Kit - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ENCODING: UTF-8 (acentos y caracteres especiales OK)
#
# 🚀 QUICK START:
# 1. cp .env.example .env.local
# 2. Create Neon DB: https://console.neon.tech
# 3. Generate AUTH_SECRET: openssl rand -base64 32
# 4. Configure SUPER_ADMIN_EMAIL for the seed
# 5. pnpm db:push (creates tables)
# 6. pnpm db:seed (creates superadmin)
# 7. pnpm dev
# 8. Go to http://localhost:3000/login

# ---------------------------------------------
# Database (Neon Postgres) - REQUIRED
# ---------------------------------------------
# Get your connection string from: https://console.neon.tech
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ---------------------------------------------
# Authentication (NextAuth.js v5) - REQUIRED
# ---------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# NextAuth.js compatibility aliases (optional)
# If not set, we use AUTH_SECRET and NEXT_PUBLIC_APP_URL
# Some SDKs/deployments expect these, so set them in production:
# NEXTAUTH_SECRET="${AUTH_SECRET}"
# NEXTAUTH_URL="${NEXT_PUBLIC_APP_URL}"

# For local development/testing, trust the host header
# Required for OAuth to work correctly in local dev
# Set to "true" for local dev, not needed in Vercel production
AUTH_TRUST_HOST="true"

# Enable NextAuth debug logs (optional, for troubleshooting)
# AUTH_DEBUG="false"

# Google OAuth (optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth (optional)
# Get credentials from: https://github.com/settings/developers
# Redirect URI: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ---------------------------------------------
# Auth Feature Flags
# ---------------------------------------------
# Use "true" or "false" (as strings, case-insensitive)
# ⚠️ IMPORTANT: At least ONE login method must be active!
#    If all are disabled and no OAuth is configured,
#    password + registration are auto-enabled as fallback.
NEXT_PUBLIC_AUTH_PASSWORD="true"
NEXT_PUBLIC_AUTH_MAGIC_LINK="false"
NEXT_PUBLIC_AUTH_REGISTRATION="true"
NEXT_PUBLIC_AUTH_PASSWORD_RESET="true"
NEXT_PUBLIC_AUTH_EMAIL_VERIFY="false"

# OAuth UI flags (set to true if you configure OAuth above)
NEXT_PUBLIC_AUTH_GOOGLE="false"
NEXT_PUBLIC_AUTH_GITHUB="false"

# ---------------------------------------------
# Notifications (Optional — graceful degradation)
# ---------------------------------------------
# Feature flag: enable/disable the entire notification system
NEXT_PUBLIC_NOTIFICATIONS_ENABLED="false"

# Web Push (VAPID) keys — optional, push disabled if not set
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@example.com"

# ---------------------------------------------
# Super Admin Seed (pnpm db:seed)
# ---------------------------------------------
# Creates the first superadmin user in the database.
# Only super_admins can promote other users to super_admin (within the app).
SUPER_ADMIN_EMAIL="admin@example.com"
# SUPER_ADMIN_PASSWORD=""   # Optional: if not set, OAuth-only
# SUPER_ADMIN_NAME=""       # Optional: defaults to "Super Admin"

# ---------------------------------------------
# Application
# ---------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="My App"
NEXT_PUBLIC_COMPANY_NAME="My Company Inc."
NEXT_PUBLIC_COUNTRY="México"

# Contact emails (used in legal pages)
NEXT_PUBLIC_LEGAL_EMAIL="legal@example.com"
NEXT_PUBLIC_PRIVACY_EMAIL="privacy@example.com"
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

# Optional: Logo URL for email templates (falls back to text if not set)
# NEXT_PUBLIC_LOGO_URL=""  # DEPRECATED - use CLIENT_LOGO_DARK instead

# Client Logo (for sidebar, auth screens, emails)
# Recommended: PNG ~400-600px ancho (ratio 4:1) con fondo transparente
# NEXT_PUBLIC_CLIENT_LOGO_LIGHT=""   # Logo for light theme backgrounds
# NEXT_PUBLIC_CLIENT_LOGO_DARK=""    # Logo for dark theme backgrounds (also used in emails)

# PWA theme colors (used by manifest.ts and branding.ts)
NEXT_PUBLIC_THEME_COLOR="#1e40af"
NEXT_PUBLIC_BG_COLOR="#0a1628"

# ---------------------------------------------
# Email Provider (for magic links & password reset)
# ---------------------------------------------
# Options: "resend" | "smtp" | "none"
# Default: "none" (email features disabled)
#
# ⚠️ To enable magic link, set EMAIL_PROVIDER to "resend" or "smtp"
#    and configure the required variables below.
EMAIL_PROVIDER="none"

# Common (required if EMAIL_PROVIDER !== "none")
# For Resend testing without verified domain: onboarding@resend.dev
EMAIL_FROM="noreply@yourdomain.com"

# Resend configuration (if EMAIL_PROVIDER="resend")
# Get your API key: https://resend.com
# RESEND_API_KEY=""

# SMTP configuration (if EMAIL_PROVIDER="smtp")
# EMAIL_SERVER_HOST="smtp.example.com"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER=""
# EMAIL_SERVER_PASSWORD=""
# EMAIL_SERVER_SECURE="false"

# (Opcional) URL pública del logo para emails.
# Si se omite, el logo se incrusta como CID inline desde logo-data.ts (recomendado).
# Útil solo si quieres alojar el logo en un CDN externo.
# EMAIL_LOGO_URL=

# ---------------------------------------------
# Rate Limiting (always ON by default — no setup required)
# ---------------------------------------------
# Rate limiting is ENABLED by default with sane limits on auth / invites /
# registration. Nothing to configure for it to work — the kit auto-selects
# the best backend at runtime:
#
#   1. Upstash Redis    (if UPSTASH_REDIS_REST_URL is set — best for multi-instance prod)
#   2. Postgres         (if DATABASE_URL is set AND NODE_ENV=production — uses Neon, no extra deps)
#   3. In-memory Map    (dev / local / single-instance fallback)
#
# All variables in this section are OPTIONAL overrides. Leave them commented
# unless you specifically need to change something.
#
# See `sk-security §7 Rate limiting` for the full design.

# ── Kill-switch (default ON) ─────────────────────────────────────────────────
# Only set to "false" in very specific cases: E2E tests that need to hammer the
# auth endpoint, local debugging, or an emergency bypass in production. Any
# other value (or unset) keeps rate limiting ENABLED.
# RATE_LIMIT_ENABLED=true

# ── Upstash Redis (opt-in for multi-instance production) ─────────────────────
# 🚀 Enable in 5 minutes via Vercel Marketplace:
#    1. https://vercel.com/integrations/upstash
#    2. Add Upstash Redis Integration
#    3. Environment variables are auto-added
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ── Per-bucket overrides (defaults are shown; uncomment to change) ───────────
# All buckets share the same shape: RATE_LIMIT_<BUCKET>_REQUESTS / _WINDOW_SECONDS.
#
# RATE_LIMIT_AUTH_REQUESTS=10              # Login (Credentials.authorize)
# RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# RATE_LIMIT_FORGOT_PASSWORD_REQUESTS=5    # /api/auth/forgot-password
# RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=60
# RATE_LIMIT_RESET_PASSWORD_REQUESTS=10    # /api/auth/reset-password
# RATE_LIMIT_RESET_PASSWORD_WINDOW_SECONDS=60
# RATE_LIMIT_REGISTER_REQUESTS=3           # /api/auth/register (3 signups per hour by default)
# RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
# RATE_LIMIT_INVITE_REQUESTS=30            # /api/invites/{send,validate,accept}
# RATE_LIMIT_INVITE_WINDOW_SECONDS=60

# ---------------------------------------------
# Sentry Error Reporting (Optional)
# ---------------------------------------------
# Only active if DSN is set. Get credentials from: https://sentry.io
#
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""  # For source map uploads (CI/CD)

# ---------------------------------------------
# Vercel Deployment (Optional — used by push-env-vercel.mjs)
# ---------------------------------------------
# API token for push-env-vercel.mjs (never pushed to Vercel itself)
# Get one at: https://vercel.com/account/tokens
# VERCEL_TOKEN=""

# Database URL using connection pooler (for Vercel serverless)
# If set, push-env-vercel.mjs replaces DATABASE_URL with this value when pushing
# DATABASE_URL_POOLER=""

# ---------------------------------------------
# E2E Testing with Neon Branching (Optional)
# ---------------------------------------------
# Enables isolated database branches for E2E tests.
# Each test run creates a temporary branch that is deleted after tests complete.
# This prevents test data from polluting your main database.
#
# 🚀 Setup: pnpm setup:e2e (interactive setup for local + CI)
#
# Manual setup:
# 1. Get NEON_API_KEY: https://console.neon.tech → Account Settings → API Keys
# 2. Get NEON_PROJECT_ID: https://console.neon.tech → Project Settings → General
#
# NEON_API_KEY=""
# NEON_PROJECT_ID=""
